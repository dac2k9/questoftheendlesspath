# Supabase credentials (get from supabase.com dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Player config
PLAYER_ID=your-player-uuid-here
GAME_ID=your-game-uuid-here

# Walker: BLE device name (found via ble_scan_cyberpad.py)
DEVICE_NAME=URTM051

# Game Master: adventure file path
ADVENTURE_PATH=adventures/dragons_path.yaml
